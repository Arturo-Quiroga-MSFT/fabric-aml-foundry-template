# Copy this file to `.env` and fill in values for your own Azure resources.
# Auth uses DefaultAzureCredential (`az login`); nothing in this file is
# expected to be a secret, but `.env` is gitignored as a safety net.

# -----------------------------------------------------------------------------
# Azure subscription / region
# -----------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group>
AZURE_LOCATION=eastus2
AZURE_TENANT_ID=<your-tenant-id>

# -----------------------------------------------------------------------------
# Azure Machine Learning
# -----------------------------------------------------------------------------
AML_WORKSPACE_NAME=<your-aml-workspace-name>
AML_COMPUTE_CLUSTER=cpu-cluster

# -----------------------------------------------------------------------------
# Key Vault + Application Insights
# -----------------------------------------------------------------------------
KEY_VAULT_NAME=<your-key-vault-name>
APP_INSIGHTS_CONNECTION_STRING=

# -----------------------------------------------------------------------------
# Microsoft Fabric / OneLake
# Workspace + lakehouse can be names or GUIDs. GUIDs are more stable.
# -----------------------------------------------------------------------------
FABRIC_WORKSPACE_NAME=<your-fabric-workspace-name-or-guid>
FABRIC_LAKEHOUSE_NAME=<your-fabric-lakehouse-name-or-guid>

# Schema name for schema-enabled lakehouses (default 'dbo').
# Leave blank for legacy lakehouses.
ONELAKE_SCHEMA=dbo
ONELAKE_TABLE=<your-table-name>

# Optional secondary dataset(s):
# ONELAKE_TABLE_TAXI=nyctaxi_yellow

# Resulting URI:
# abfss://<workspace>@onelake.dfs.fabric.microsoft.com/<lakehouse>.Lakehouse/Tables/[<schema>/]<table>

# -----------------------------------------------------------------------------
# User-Assigned Managed Identity used by AML to access OneLake
# -----------------------------------------------------------------------------
USER_ASSIGNED_MI_CLIENT_ID=<your-mi-client-id>
USER_ASSIGNED_MI_PRINCIPAL_ID=<your-mi-principal-id>

# -----------------------------------------------------------------------------
# Online endpoint (used by smoke test + MCP server)
# -----------------------------------------------------------------------------
AML_ENDPOINT_NAME=<your-endpoint-name>
AML_ENDPOINT_URL=https://<your-endpoint-name>.<region>.inference.ml.azure.com/score
